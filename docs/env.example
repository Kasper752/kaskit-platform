# Shared
NODE_ENV=development

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WIDGET_URL=http://localhost:4000/widget.js

# Backend
PORT=4000
APP_ORIGIN=http://localhost:3000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/kaskit_platform
SESSION_COOKIE_NAME=kaskit_session
SESSION_SECRET=change-me-with-32-plus-random-characters
PASSWORD_MIN_LENGTH=10

# Email / SMS providers are intentionally abstract for MVP
EMAIL_FROM=no-reply@app.kaskit.ru
SMS_PROVIDER=stub
SMS_MONTHLY_DEFAULT_LIMIT=300

